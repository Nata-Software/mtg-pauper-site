// MTG Pauper stats — schema
// Data comes from two Google Sheet tabs exported as CSV: Ranking + Rounds.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// One row per player per match (mirrored: each match stored twice, once per side).
// Source: Rounds CSV.
model Match {
  id             Int      @id @default(autoincrement())
  store          String   @default("default")
  eventName      String
  date           DateTime?
  round          Int
  player         String
  deck           String
  playerScore    Int
  result         String // "win" | "loss" | "draw"
  opponent       String
  opponentDeck   String
  opponentScore  Int
  tournamentId   String? // melee tournament id (null for CSV-imported history)
  tournamentName String?
  // Card-based archetype (denormalized from Decklist for simple queries).
  // Null for legacy CSV data with no decklist -> views fall back to `deck`.
  decklistId         String?
  opponentDecklistId String?
  archetype          String?
  opponentArchetype  String?
  createdAt      DateTime @default(now())

  @@index([store, deck, opponentDeck])
  @@index([store, date])
  @@index([store, tournamentId])
  @@index([store, archetype, opponentArchetype])
}

// One scraped decklist with its actual cards. The cards are the source of
// truth: re-classifying (changing the rules) re-runs over these, no re-scrape.
model Decklist {
  id           String   @id // melee DecklistId (GUID)
  tournamentId String?
  player       String
  rawName      String // player-typed deck name
  archetype    String // card-based classification
  cards        Json // [{ qty, slug, name }]
  createdAt    DateTime @default(now())

  @@index([tournamentId])
}

// Fixed-window rate limiting for admin endpoints, keyed by "action:ip".
// DB-backed so it holds across serverless instances (in-memory would not).
model RateLimit {
  id          String   @id
  count       Int      @default(0)
  windowStart DateTime @default(now())
}

// One row per player per event (standings). Source: Ranking CSV.
model Standing {
  id             Int      @id @default(autoincrement())
  store          String   @default("default")
  eventName      String
  date           DateTime?
  nickname       String
  fullName       String
  points         Int
  position       Int
  deck           String
  archetype      String?
  tournamentId   String?
  tournamentName String?
  createdAt      DateTime @default(now())

  @@index([store, eventName])
  @@index([store, date])
  @@index([store, tournamentId])
}
