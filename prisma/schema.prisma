// MTG Pauper stats — schema
// Data comes from two Google Sheet tabs exported as CSV: Ranking + Rounds.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// One row per player per match (mirrored: each match stored twice, once per side).
// Source: Rounds CSV.
model Match {
  id             Int      @id @default(autoincrement())
  store          String   @default("default")
  eventName      String
  date           DateTime?
  round          Int
  player         String
  deck           String
  playerScore    Int
  result         String // "win" | "loss" | "draw"
  opponent       String
  opponentDeck   String
  opponentScore  Int
  tournamentId   String? // melee tournament id (null for CSV-imported history)
  tournamentName String?
  createdAt      DateTime @default(now())

  @@index([store, deck, opponentDeck])
  @@index([store, date])
  @@index([store, tournamentId])
}

// One row per player per event (standings). Source: Ranking CSV.
model Standing {
  id             Int      @id @default(autoincrement())
  store          String   @default("default")
  eventName      String
  date           DateTime?
  nickname       String
  fullName       String
  points         Int
  position       Int
  deck           String
  tournamentId   String?
  tournamentName String?
  createdAt      DateTime @default(now())

  @@index([store, eventName])
  @@index([store, date])
  @@index([store, tournamentId])
}
